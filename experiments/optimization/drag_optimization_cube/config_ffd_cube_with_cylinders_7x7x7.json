{
  "results_name": "results_ffd_cube_with_cylinders_7x7x7",
  "reconstruction": {
    "mesh_path": "${DEEPSHAPEOPT_DATA_DIR}/shapes/cube_with_cylinders.stl",
    "n_control_points": [7, 7, 7],
    "spline_degree": [2, 2, 2],
    "design_domain": [[-0.9, -0.9, -0.9], [0.9, 0.9, 0.9]],
    "device": "cuda"
  },
  "optimization": {
    "num_iter": 60,
    "mesh_resolution": 64,
    "max_step": 0.05,
    "bounds": [-5.0, 5.0],
    "use_center_constraint": true,
    "center_tol": 0.05,
    "convergence_obj_tol": 0.0002,
    "convergence_window": 3,
    "heavy_data_output_path": "${DEEPSHAPEOPT_RESULTS_DIR}",
    "sensitivity": {
      "loading_method": "conservative",
      "field_name": "pointSensVecadjS1ESI",
      "objective_path": "optimisation/objective/0/dragadjS1",
      "invert_normals": true
    },
    "use_jacobian_constraint": true,
    "jacobian_threshold": 0.1,
    "jacobian_samples": 16
  }

}
